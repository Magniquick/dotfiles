[Unit]
Description=Shadow native host daemon
Documentation=file:/home/magni/Projects/shadow/docs/local-extension.md

[Service]
Type=simple
ExecStart=%h/Projects/shadow/native-host/target/release/shadow-native-host --daemon
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=1

[Install]
WantedBy=default.target
