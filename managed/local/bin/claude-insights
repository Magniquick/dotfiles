// ─── Main ─────────────────────────────────────────────────────────────────────

// Returns true if a session is a meta-session (the insights tool analyzing itself)
// mirrors M() filter in wj9
function isMetaSession(session) {
  for (const m of session.messages.slice(0, 5)) {
    if (m.type !== "user" || !m.message) continue;
    const c = m.message.content;
    if (typeof c === "string" &&
        (c.includes("RESPOND WITH ONLY A VALID JSON OBJECT") || c.includes("record_facets")))
      return true;
  }
  return false;
}

// Returns true if a session has valid timestamps (mirrors Aj9)
function hasValidTimestamps(session) {
  return !Number.isNaN(session.created.getTime()) && !Number.isNaN(session.modified.getTime());
}

async function main() {
  const MAX_UNCACHED = 200;   // max new JSONL files to parse (mirrors D=200 in wj9)
  const MAX_FACET_SESSIONS = 50;  // max sessions to extract facets for (mirrors P=50)

  process.stderr.write("Discovering sessions...\n");
  const files = await findSessionFiles();
  const totalScanned = files.length;
  process.stderr.write(`Found ${totalScanned} session files\n`);

  // Parse sessions: batch-load JSONL files, apply meta/timestamp filters,
  // deduplicate by keeping best version (most messages, then longest duration)
  // Mirrors wj9's session collection loop
  const bySessionId = new Map();  // sessionId -> best session object
  let uncachedCount = 0;

  for (const f of files) {
    if (uncachedCount >= MAX_UNCACHED) break;
    let text;
    try { text = await readFile(f.path, "utf8"); } catch { continue; }
    uncachedCount++;
    const parsed = parseSessionFile(text);
    for (const s of parsed) {
      if (!hasValidTimestamps(s)) continue;
      if (isMetaSession(s)) continue;
      const existing = bySessionId.get(s.sessionId);
      if (!existing) {
        bySessionId.set(s.sessionId, s);
      } else {
        // Keep the version with more user messages; tie-break by duration
        const sCount = s.messages.filter(m => m.type === "user").length;
        const eCount = existing.messages.filter(m => m.type === "user").length;
        const sDur = s.modified.getTime() - s.created.getTime();
        const eDur = existing.modified.getTime() - existing.created.getTime();
        if (sCount > eCount || (sCount === eCount && sDur > eDur))
          bySessionId.set(s.sessionId, s);
      }
    }
  }

  // Valid session filter: user_message_count >= 2 AND duration_minutes >= 1 (mirrors X())
  const allSessions = [...bySessionId.values()].sort(
    (a, b) => b.created.getTime() - a.created.getTime()
  );
  const sessions = allSessions.filter(s => {
    const meta = sessionMeta(s);
    return meta.user_message_count >= 2 && meta.duration_minutes >= 1;
  });

  const isWarmup = (facet) => {
    if (!facet) return false;
    const cats = Object.entries(facet.goal_categories || {}).filter(([, v]) => v > 0).map(([k]) => k);
    return cats.length === 1 && cats[0] === "warmup_minimal";
  };

  process.stderr.write(`Extracted ${sessions.length} sessions\n`);

  // Load existing facets, queue new sessions for extraction (up to MAX_FACET_SESSIONS)
  process.stderr.write("Loading/extracting facets...\n");
  const facetsMap = new Map();
  const toExtract = [];

  for (const s of sessions) {
    const cached = await loadFacet(s.sessionId);
    if (cached) {
      facetsMap.set(s.sessionId, cached);
    } else if (toExtract.length < MAX_FACET_SESSIONS) {
      toExtract.push(s);
    }
  }

  // Extract facets in batches of 50 (mirrors C=50 in wj9)
  const BATCH = 50;
  for (let i = 0; i < toExtract.length; i += BATCH) {
    process.stderr.write(`Extracting facets ${i + 1}-${Math.min(i + BATCH, toExtract.length)} of ${toExtract.length}...\n`);
    const batch = toExtract.slice(i, i + BATCH);
    const results = await Promise.all(batch.map(s => extractFacets(s).catch(() => null)));
    for (let j = 0; j < batch.length; j++) {
      if (results[j]) facetsMap.set(batch[j].sessionId, results[j]);
    }
  }

  // Build metas and filter out warmup sessions
  const metas = sessions.map(s => sessionMeta(s));
  const filteredMetas = metas.filter(m => !isWarmup(facetsMap.get(m.session_id)));
  const filteredFacets = new Map([...facetsMap].filter(([k]) => !isWarmup(facetsMap.get(k))));

  const agg = aggregateStats(filteredMetas, filteredFacets);
  agg.total_sessions_scanned = totalScanned;  // mirrors z.total_sessions_scanned = L in wj9
  process.stderr.write(`Aggregated ${filteredMetas.length} sessions (${sessions.length - filteredMetas.length} warmup filtered)\n`);

  // Build condensed data string (mirrors Kj9's B variable)
  const sectionData = buildSectionData(agg, filteredFacets);

  // Pass 1: generate all sections except at_a_glance in parallel
  process.stderr.write("Generating report sections...\n");
  const sectionResults = await Promise.all(SECTIONS.map(s => generateSection(s, sectionData)));

  const insights = {};
  for (const { name, result } of sectionResults) {
    if (result) insights[name] = result;
  }

  // Pass 2: generate at_a_glance with context from all other sections (mirrors Kj9)
  process.stderr.write("Generating at-a-glance summary...\n");
  const glance = await generateAtAGlance(sectionData, insights);
  if (glance) insights.at_a_glance = glance;

  const html = renderHtml(insights, agg);
  const USAGE_DIR = join(CONFIG_DIR, "usage-data");
  await mkdir(USAGE_DIR, { recursive: true });
  const htmlPath = join(USAGE_DIR, "report.html");
  await writeFile(htmlPath, html, { encoding: "utf-8", mode: 0o600 });

  const fileUrl = `file://${htmlPath}`;
  process.stdout.write(`Your shareable insights report is ready:\n${fileUrl}\n\nWant to dig into any section or try one of the suggestions?\n`);
}

main().catch(e => { process.stderr.write(`Error: ${e.message}\n`); process.exit(1); });
