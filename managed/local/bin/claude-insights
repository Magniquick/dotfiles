      <p style="font-size:12px;color:#64748b;margin-bottom:12px;">Just copy this into Claude Code to add it to your CLAUDE.md.</p>
      <div class="claude-md-actions"><button class="copy-all-btn" onclick="copyAllCheckedClaudeMd()">Copy All Checked</button></div>
      ${sg.claude_md_additions.map((h,i) => `
        <div class="claude-md-item">
          <input type="checkbox" id="cmd-${i}" class="cmd-checkbox" checked data-text="${esc(h.prompt_scaffold||"Add to CLAUDE.md")}\\n\\n${esc(h.addition)}">
          <label for="cmd-${i}">
            <code class="cmd-code">${esc(h.addition)}</code>
