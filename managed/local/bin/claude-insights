#!/usr/bin/env bun
// claude-insights: Standalone reimplementation of the /insights built-in.
// Reads ~/.config/claude/projects/ session JSONL files, extracts facets via
// claude -p, aggregates stats, generates report sections, and writes HTML.

import { readdir, readFile, writeFile, mkdir, stat } from "fs/promises";
import { join, extname, basename } from "path";
import { spawnSync } from "child_process";
import { homedir } from "os";
import { createHash } from "crypto";
import { diffLines } from "diff";

const HOME = homedir();
const CONFIG_DIR = join(HOME, ".config", "claude");
const PROJECTS_DIR = join(CONFIG_DIR, "projects");
const FACETS_DIR = join(CONFIG_DIR, "usage-data", "facets");
const META_DIR = join(CONFIG_DIR, "usage-data", "session-meta");

const EXT_LANG = {
  ".ts": "TypeScript", ".tsx": "TypeScript",
  ".js": "JavaScript", ".jsx": "JavaScript",
  ".py": "Python", ".rb": "Ruby", ".go": "Go", ".rs": "Rust",
  ".java": "Java", ".md": "Markdown", ".json": "JSON",
  ".yaml": "YAML", ".yml": "YAML", ".sh": "Shell",
  ".css": "CSS", ".html": "HTML",
};

// ─── Session discovery ──────────────────────────────────────────────────────

async function findSessionFiles() {
  let files = [];
  let projectDirs;
  try {
    projectDirs = await readdir(PROJECTS_DIR, { withFileTypes: true });
  } catch {
    return [];
  }
  for (const d of projectDirs) {
    if (!d.isDirectory()) continue;
    const dir = join(PROJECTS_DIR, d.name);
    let entries;
    try {
      entries = await readdir(dir, { withFileTypes: true });
    } catch {
      continue;
    }
    for (const f of entries) {
      if (!f.isFile() || !f.name.endsWith(".jsonl")) continue;
      const path = join(dir, f.name);
      try {
        const s = await stat(path);
        files.push({ path, mtime: s.mtimeMs, size: s.size });
      } catch {}
    }
  }
  return files.sort((a, b) => b.mtime - a.mtime);
}

// ─── Session parsing ─────────────────────────────────────────────────────────

// Valid message types that participate in the parentUuid chain (mirrors kl() in built-in)
const CHAIN_TYPES = new Set(["user", "assistant", "system", "progress", "attachment"]);

// Matches user message content that is purely system/tool noise, not a real user prompt
// (mirrors BDB in built-in; aw="tick" per bundle constants at offset 1048498)
const NOISE_MSG = /^(?:<local-command-stdout>|<session-start-hook>|<tick>|\[Request interrupted by user[^\]]*\]|\s*<ide_opened_file>[\s\S]*<\/ide_opened_file>\s*$|\s*<ide_selection>[\s\S]*<\/ide_selection>\s*$)/;

// Extract text from an XML-like tag (simplified LB)
function extractTag(text, tag) {
  const re = new RegExp(`<${tag}(?:\\s[^>]*)?>([\\s\\S]*?)<\\/${tag}>`, "i");
  const m = re.exec(text);
  return m ? m[1] : null;
}

// Extract first meaningful user prompt from chain (mirrors BlA/QR$ in built-in)
function extractFirstPrompt(chain) {
  for (const m of chain) {
    if (m.type !== "user" || m.isMeta) continue;
    if (m.isCompactSummary) continue;
    const content = m.message?.content;
    if (!content) continue;
    const texts = typeof content === "string" ? [content]
      : Array.isArray(content) ? content.filter(b => b.type === "text" && b.text).map(b => b.text)
      : [];
    for (const t of texts) {
      if (!t) continue;
      // Command invocation: return "/name args" or skip known built-ins
      const cmdName = extractTag(t, "command-name");
      if (cmdName) {
        const args = extractTag(t, "command-args")?.trim();
        if (!args) continue;  // built-in command with no args — skip
        const raw = `${cmdName.replace(/^\//, "")} ${args}`.trim();
        const result = raw.length > 200 ? raw.slice(0, 200).trim() + "…" : raw;
        return result;
      }
      // Skip tool-result-only / system noise
      if (NOISE_MSG.test(t)) continue;
      // Bash input shorthand
      const bash = extractTag(t, "bash-input");
      if (bash) {
        const s = `! ${bash}`;
        return s.length > 200 ? s.slice(0, 200).trim() + "…" : s;
      }
      // Plain text — this is the first real prompt
      const s = t.replace(/\n/g, " ").trim();
      if (!s) continue;
      return s.length > 200 ? s.slice(0, 200).trim() + "…" : s;
    }
  }
  return "No prompt";
}

// Strip isSidechain and parentUuid from messages before storing (mirrors flA)
function stripChainFields(chain) {
  return chain.map(({ isSidechain, parentUuid, ...rest }) => rest);
}

function parseSessionFile(text) {
  // Build message tree including ALL chain types (progress/system can sit between user/assistant)
  const byUuid = new Map();
  const children = new Map();  // uuid -> [child uuids]
  const summaries = new Map(); // leafUuid -> summary string
  let projectPath = "";

  for (const line of text.split("\n")) {
    if (!line.trim()) continue;
    let rec;
    try { rec = JSON.parse(line); } catch { continue; }
    // Collect summary metadata records (mirrors SMH's summary handling)
    if (rec.type === "summary" && rec.leafUuid && rec.summary) {
      summaries.set(rec.leafUuid, rec.summary);
      continue;
    }
    if (!rec.uuid || !CHAIN_TYPES.has(rec.type)) continue;
    if (!projectPath && rec.cwd) projectPath = rec.cwd;
    // Strip normalizedMessages from progress records to avoid carrying large blobs (mirrors SMH)
    if (rec.type === "progress" && rec.data && typeof rec.data === "object" &&
        Array.isArray(rec.data.normalizedMessages) && rec.data.normalizedMessages.length > 0) {
      rec.data.normalizedMessages = [];
    }
    byUuid.set(rec.uuid, rec);
    const parent = rec.parentUuid ?? null;
    if (!children.has(parent)) children.set(parent, []);
    children.get(parent).push(rec.uuid);
  }

  if (byUuid.size === 0) return [];

  // Find raw leaf nodes: no record has them as a parentUuid
  const rawLeaves = [...byUuid.keys()].filter(u => !children.has(u));

  // For each raw leaf, walk backwards to find the nearest user/assistant ancestor —
  // that is the actual conversation leaf (mirrors SMH's leaf-pruning logic)
  const sessions = [];
  const processedLeaves = new Set();

  for (const rawLeaf of rawLeaves) {
    let leafRec = null;
    let cur = byUuid.get(rawLeaf);
    const seen = new Set();
    while (cur) {
      if (seen.has(cur.uuid)) break;  // cycle guard
      seen.add(cur.uuid);
      if (cur.type === "user" || cur.type === "assistant") { leafRec = cur; break; }
      cur = cur.parentUuid ? byUuid.get(cur.parentUuid) : null;
    }
    if (!leafRec || processedLeaves.has(leafRec.uuid)) continue;
    processedLeaves.add(leafRec.uuid);

    // Build full chain from root to leaf (including progress/system for correct traversal)
    const chain = [];
    cur = leafRec;
    const chainSeen = new Set();
    while (cur) {
      if (chainSeen.has(cur.uuid)) break;
      chainSeen.add(cur.uuid);
      chain.unshift(cur);
      cur = cur.parentUuid ? byUuid.get(cur.parentUuid) : null;
    }
    if (chain.length < 2) continue;

    const first = chain[0];
    const sessionId = first.sessionId || createHash("md5").update(first.uuid).digest("hex");

    // Continuation messages: non-user/assistant children of the leaf appended after the
    // final turn (e.g. progress/system metadata records). Mirrors Fv$'s `w` variable.
    const continuations = (children.get(leafRec.uuid) || [])
      .map(uuid => byUuid.get(uuid))
      .filter(m => m && m.type !== "user" && m.type !== "assistant")
      .sort((a, b) => new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime());
    chain.push(...continuations);

    sessions.push({
      sessionId,
      leafUuid: leafRec.uuid,
      created: new Date(first.timestamp),
      modified: new Date(leafRec.timestamp),     // mirrors Fv$: modified: new Date(C.timestamp)
      projectPath: projectPath || first.cwd || "",
      firstPrompt: extractFirstPrompt(chain),    // mirrors BlA()
      summary: summaries.get(leafRec.uuid),      // mirrors L.get(C.uuid) in Fv$
      messages: stripChainFields(chain),          // mirrors flA(_)
    });
  }
  return sessions;
}

// ─── Stats extraction (mirrors $j9 in built-in) ──────────────────────────────

function extractStats(session) {
  const toolCounts = {}, languages = {};
  let gitCommits = 0, gitPushes = 0, inputTokens = 0, outputTokens = 0;
  let userInterruptions = 0, toolErrors = 0;
  const toolErrorCategories = {};
  let usesTaskAgent = false, usesMcp = false, usesWebSearch = false, usesWebFetch = false;
  let linesAdded = 0, linesRemoved = 0;
  const filesModified = new Set();
  const messageHours = [], userMessageTimestamps = [];
  const userResponseTimes = [];
  let lastAssistantTs = null;

  for (const m of session.messages) {
    const ts = m.timestamp;

    if (m.type === "assistant" && m.message) {
      if (ts) lastAssistantTs = ts;
      const usage = m.message.usage;
      if (usage) {
        inputTokens += usage.input_tokens || 0;
        outputTokens += usage.output_tokens || 0;
      }
      const content = m.message.content;
      if (Array.isArray(content)) {
        for (const block of content) {
          if (block.type !== "tool_use" || !block.name) continue;
          const name = block.name;
          toolCounts[name] = (toolCounts[name] || 0) + 1;
          if (name === "Task" || name === "dispatch_agent") usesTaskAgent = true;
          if (name.startsWith("mcp__")) usesMcp = true;
          if (name === "WebSearch") usesWebSearch = true;
          if (name === "WebFetch") usesWebFetch = true;
          const inp = block.input || {};
          const fp = inp.file_path || "";
          if (fp) {
            const ext = extname(fp).toLowerCase();
            if (EXT_LANG[ext]) languages[EXT_LANG[ext]] = (languages[EXT_LANG[ext]] || 0) + 1;
            if (name === "Edit" || name === "Write") filesModified.add(fp);
          }
          if (name === "Edit") {
            const oldStr = inp.old_string || "", newStr = inp.new_string || "";
            for (const hunk of diffLines(oldStr, newStr)) {
              if (hunk.added) linesAdded += hunk.count || 0;
              if (hunk.removed) linesRemoved += hunk.count || 0;
            }
          }
          if (name === "Write") {
            linesAdded += ((inp.content || "").match(/\n/g) || []).length;
          }
          const cmd = inp.command || "";
          if (cmd.includes("git commit")) gitCommits++;
          if (cmd.includes("git push")) gitPushes++;
        }
      }
    }

    if (m.type === "user" && m.message) {
      const content = m.message.content;
      let hasText = false;
      if (typeof content === "string" && content.trim()) hasText = true;
      else if (Array.isArray(content)) {
        hasText = content.some(b => b.type === "text" && b.text && b.text.trim());
      }
      if (hasText && ts) {
        try {
          const h = new Date(ts).getHours();
          messageHours.push(h);
          userMessageTimestamps.push(ts);
          if (lastAssistantTs) {
            const dt = (new Date(ts).getTime() - new Date(lastAssistantTs).getTime()) / 1000;
            if (dt > 2 && dt < 3600) userResponseTimes.push(dt);
          }
        } catch {}
      }
      if (Array.isArray(content)) {
        for (const b of content) {
          if (b.type === "tool_result" && b.is_error) {
            toolErrors++;
            const txt = (typeof b.content === "string" ? b.content : "").toLowerCase();
            let cat = "Other";
            if (txt.includes("exit code")) cat = "Command Failed";
            else if (txt.includes("rejected") || txt.includes("doesn't want")) cat = "User Rejected";
            else if (txt.includes("string to replace not found") || txt.includes("no changes")) cat = "Edit Failed";
            else if (txt.includes("modified since read")) cat = "File Changed";
            else if (txt.includes("exceeds maximum") || txt.includes("too large")) cat = "File Too Large";
            else if (txt.includes("file not found") || txt.includes("does not exist")) cat = "File Not Found";
            toolErrorCategories[cat] = (toolErrorCategories[cat] || 0) + 1;
          }
        }
      }
      const txt = typeof content === "string" ? content : JSON.stringify(content);
      if (txt.includes("[Request interrupted by user")) userInterruptions++;
    }
  }

  return {
    toolCounts, languages, gitCommits, gitPushes, inputTokens, outputTokens,
    userInterruptions, userResponseTimes, toolErrors, toolErrorCategories,
    usesTaskAgent, usesMcp, usesWebSearch, usesWebFetch,
    linesAdded, linesRemoved, filesModified,
    messageHours, userMessageTimestamps,
  };
}

function sessionMeta(session) {
  const stats = extractStats(session);
  let userMsgCount = 0, assistantMsgCount = 0;
  for (const m of session.messages) {
    // mirrors sj9(): skip isMeta, count text/image/document content (not tool-result-only)
    if (m.type === "user" && !m.isMeta && m.message) {
      const c = m.message.content;
      const valid = typeof c === "string" ? c.trim().length > 0
        : Array.isArray(c) && c.some(b => b.type === "text" || b.type === "image" || b.type === "document");
      if (valid) userMsgCount++;
    }
    // mirrors ej9(): only count assistant messages that have non-empty text content
    if (m.type === "assistant" && m.message) {
      const c = m.message.content;
      if (Array.isArray(c) && c.some(b => b.type === "text" && typeof b.text === "string" && b.text.trim().length > 0))
        assistantMsgCount++;
    }
  }
  return {
    session_id: session.sessionId,
    project_path: session.projectPath,
    start_time: session.created.toISOString(),
    duration_minutes: Math.round((session.modified.getTime() - session.created.getTime()) / 60000),
    user_message_count: userMsgCount,
    assistant_message_count: assistantMsgCount,
    tool_counts: stats.toolCounts,
    languages: stats.languages,
    git_commits: stats.gitCommits,
    git_pushes: stats.gitPushes,
    input_tokens: stats.inputTokens,
    output_tokens: stats.outputTokens,
    first_prompt: session.firstPrompt,
    summary: session.summary,
    user_interruptions: stats.userInterruptions,
    user_response_times: stats.userResponseTimes,
    tool_errors: stats.toolErrors,
    tool_error_categories: stats.toolErrorCategories,
    uses_task_agent: stats.usesTaskAgent,
    uses_mcp: stats.usesMcp,
    uses_web_search: stats.usesWebSearch,
    uses_web_fetch: stats.usesWebFetch,
    lines_added: stats.linesAdded,
    lines_removed: stats.linesRemoved,
    files_modified: stats.filesModified.size,
    message_hours: stats.messageHours,
    user_message_timestamps: stats.userMessageTimestamps,
  };
}

// ─── Session text formatting for Claude ──────────────────────────────────────

function sessionToText(session) {
  const meta = sessionMeta(session);
  const lines = [
    `Session: ${meta.session_id.slice(0, 8)}`,
    `Date: ${meta.start_time}`,
    `Project: ${meta.project_path}`,
    `Duration: ${meta.duration_minutes} min`,
    "",
  ];
  for (const m of session.messages) {
    if (m.type === "user" && m.message) {
      const c = m.message.content;
      if (typeof c === "string") lines.push(`[User]: ${c.slice(0, 500)}`);
      else if (Array.isArray(c)) {
        for (const b of c)
          if (b.type === "text" && b.text) lines.push(`[User]: ${b.text.slice(0, 500)}`);
      }
    } else if (m.type === "assistant" && m.message) {
      const c = m.message.content;
      if (Array.isArray(c)) {
        for (const b of c) {
          if (b.type === "text" && b.text) lines.push(`[Assistant]: ${b.text.slice(0, 300)}`);
          else if (b.type === "tool_use" && b.name) lines.push(`[Tool: ${b.name}]`);
        }
      }
    }
  }
  return lines.join("\n");
}

// ─── Call claude -p ───────────────────────────────────────────────────────────

function claudeQuery(prompt, maxTokens = 4096) {
  const result = spawnSync(
    "claude",
    ["-p", "--max-turns", "1", "--output-format", "text"],
    {
      input: prompt,
      encoding: "utf8",
      maxBuffer: 10 * 1024 * 1024,
      timeout: 120000,
      env: { ...process.env },
    }
  );
  if (result.error) throw result.error;
  return (result.stdout || "").trim();
}

function extractJson(text) {
  const m = text.match(/\{[\s\S]*\}/);
  if (!m) return null;
  try { return JSON.parse(m[0]); } catch { return null; }
}

// ─── Facet extraction (mirrors Uj9) ──────────────────────────────────────────

const FACET_PROMPT = `Analyze this Claude Code session and extract structured facets.

CRITICAL GUIDELINES:

1. **goal_categories**: Count ONLY what the USER explicitly asked for.
   - DO NOT count Claude's autonomous codebase exploration
   - DO NOT count work Claude decided to do on its own
   - ONLY count when user says "can you...", "please...", "I need...", "let's..."

2. **user_satisfaction_counts**: Base ONLY on explicit user signals.
   - "Yay!", "great!", "perfect!" → happy
   - "thanks", "looks good", "that works" → satisfied
   - "ok, now let's..." (continuing without complaint) → likely_satisfied
   - "that's not right", "try again" → dissatisfied
   - "this is broken", "I give up" → frustrated

3. **friction_counts**: Be specific about what went wrong.
   - misunderstood_request: Claude interpreted incorrectly
   - wrong_approach: Right goal, wrong solution method
   - buggy_code: Code didn't work correctly
   - user_rejected_action: User said no/stop to a tool call
   - excessive_changes: Over-engineered or changed too much

4. If very short or just warmup, use warmup_minimal for goal_category

SESSION:
`;

async function extractFacets(session) {
  const cached = await loadFacet(session.sessionId);
  if (cached) return cached;

  let text = sessionToText(session);
  if (text.length > 30000) {
    // Summarize in chunks, then prepend session header (mirrors Bj9 in built-in)
    const chunkSize = 25000;
    const chunks = [];
    for (let i = 0; i < text.length; i += chunkSize) chunks.push(text.slice(i, i + chunkSize));
    const summaries = await Promise.all(chunks.map(c => claudeQuery(
      `Summarize this portion of a Claude Code session transcript. Focus on:\n1. What the user asked for\n2. What Claude did (tools used, files modified)\n3. Any friction or issues\n4. The outcome\n\nKeep it concise - 3-5 sentences.\n\nTRANSCRIPT CHUNK:\n${c}`
    ).catch(() => c.slice(0, 2000))));
    const meta = sessionMeta(session);
    const header = [
      `Session: ${meta.session_id.slice(0, 8)}`,
      `Date: ${meta.start_time}`,
      `Project: ${meta.project_path}`,
      `Duration: ${meta.duration_minutes} min`,
      `[Long session - ${chunks.length} parts summarized]`,
      "",
    ].join("\n");
    text = header + summaries.join("\n\n---\n\n");
  }

  const prompt = `${FACET_PROMPT}${text}

RESPOND WITH ONLY A VALID JSON OBJECT matching this schema:
{
  "underlying_goal": "What the user fundamentally wanted to achieve",
  "goal_categories": {"category_name": count},
  "outcome": "fully_achieved|mostly_achieved|partially_achieved|not_achieved|unclear_from_transcript",
  "user_satisfaction_counts": {"level": count},
  "claude_helpfulness": "unhelpful|slightly_helpful|moderately_helpful|very_helpful|essential",
  "session_type": "single_task|multi_task|iterative_refinement|exploration|quick_question",
  "friction_counts": {"friction_type": count},
  "friction_detail": "One sentence describing friction or empty string",
  "primary_success": "none|fast_accurate_search|correct_code_edits|good_explanations|proactive_help|multi_file_changes|good_debugging",
  "brief_summary": "One sentence: what user wanted and whether they got it",
  "user_instructions_to_claude": ["Any explicit standing instructions the user gave Claude, e.g. 'always use bun', 'never auto-commit'"]
}`;

  const raw = await Promise.resolve(claudeQuery(prompt)).catch(() => "");
  const facets = extractJson(raw);
  if (!facets) return null;

  const result = { ...facets, session_id: session.sessionId };
  await saveFacet(result);
  return result;
}

// ─── Facet cache ──────────────────────────────────────────────────────────────

async function loadFacet(sessionId) {
  try {
    const text = await readFile(join(FACETS_DIR, `${sessionId}.json`), "utf8");
    return JSON.parse(text);
  } catch { return null; }
}

async function saveFacet(facet) {
  await mkdir(FACETS_DIR, { recursive: true });
  await writeFile(join(FACETS_DIR, `${facet.session_id}.json`), JSON.stringify(facet, null, 2), { mode: 0o600 });
}

// ─── Stats aggregation (mirrors Xj9) ─────────────────────────────────────────

function aggregateStats(metas, facetsMap) {
  const agg = {
    total_sessions: metas.length,
    sessions_with_facets: facetsMap.size,
    date_range: { start: "", end: "" },
    total_messages: 0, total_duration_hours: 0,
    total_input_tokens: 0, total_output_tokens: 0,
    tool_counts: {}, languages: {}, git_commits: 0, git_pushes: 0,
    projects: {}, goal_categories: {}, outcomes: {},
    satisfaction: {}, helpfulness: {}, session_types: {}, friction: {}, success: {},
    session_summaries: [],
    total_interruptions: 0, total_tool_errors: 0, tool_error_categories: {},
    sessions_using_task_agent: 0, sessions_using_mcp: 0,
    sessions_using_web_search: 0, sessions_using_web_fetch: 0,
    total_lines_added: 0, total_lines_removed: 0, total_files_modified: 0,
    days_active: 0, messages_per_day: 0,
    user_response_times: [], median_response_time: 0, avg_response_time: 0,
    multi_clauding: { overlap_events: 0, sessions_involved: 0, user_messages_during: 0 },
  };

  const dates = [];
  const allResponseTimes = [];
  for (const m of metas) {
    dates.push(m.start_time);
    agg.total_messages += m.user_message_count;
    agg.total_duration_hours += m.duration_minutes / 60;
    agg.total_input_tokens += m.input_tokens;
    agg.total_output_tokens += m.output_tokens;
    agg.git_commits += m.git_commits;
    agg.git_pushes += m.git_pushes;
    agg.total_interruptions += m.user_interruptions;
    agg.total_tool_errors += m.tool_errors;
    allResponseTimes.push(...(m.user_response_times || []));
    if (m.uses_task_agent) agg.sessions_using_task_agent++;
    if (m.uses_mcp) agg.sessions_using_mcp++;
    if (m.uses_web_search) agg.sessions_using_web_search++;
    if (m.uses_web_fetch) agg.sessions_using_web_fetch++;
    agg.total_lines_added += m.lines_added;
    agg.total_lines_removed += m.lines_removed;
    agg.total_files_modified += m.files_modified;

    for (const [k, v] of Object.entries(m.tool_counts || {}))
      agg.tool_counts[k] = (agg.tool_counts[k] || 0) + v;
    for (const [k, v] of Object.entries(m.languages || {}))
      agg.languages[k] = (agg.languages[k] || 0) + v;
    for (const [k, v] of Object.entries(m.tool_error_categories || {}))
      agg.tool_error_categories[k] = (agg.tool_error_categories[k] || 0) + v;
    if (m.project_path) agg.projects[m.project_path] = (agg.projects[m.project_path] || 0) + 1;

    const facet = facetsMap.get(m.session_id);
    if (facet) {
      for (const [k, v] of Object.entries(facet.goal_categories || {}))
        if (v > 0) agg.goal_categories[k] = (agg.goal_categories[k] || 0) + v;
      agg.outcomes[facet.outcome] = (agg.outcomes[facet.outcome] || 0) + 1;
      for (const [k, v] of Object.entries(facet.user_satisfaction_counts || {}))
        if (v > 0) agg.satisfaction[k] = (agg.satisfaction[k] || 0) + v;
      agg.helpfulness[facet.claude_helpfulness] = (agg.helpfulness[facet.claude_helpfulness] || 0) + 1;
      agg.session_types[facet.session_type] = (agg.session_types[facet.session_type] || 0) + 1;
      for (const [k, v] of Object.entries(facet.friction_counts || {}))
        if (v > 0) agg.friction[k] = (agg.friction[k] || 0) + v;
      if (facet.primary_success && facet.primary_success !== "none")
        agg.success[facet.primary_success] = (agg.success[facet.primary_success] || 0) + 1;
    }

    if (agg.session_summaries.length < 50) {
      agg.session_summaries.push({
        id: m.session_id.slice(0, 8),
        date: m.start_time.split("T")[0] || "",
        summary: facet?.brief_summary || m.first_prompt.slice(0, 100),
        goal: facet?.underlying_goal,
      });
    }
  }

  dates.sort();
  agg.date_range.start = dates[0]?.split("T")[0] || "";
  agg.date_range.end = dates[dates.length - 1]?.split("T")[0] || "";
  const activeDays = new Set(dates.map(d => d.split("T")[0]));
  agg.days_active = activeDays.size;
  agg.messages_per_day = agg.days_active > 0 ? Math.round(agg.total_messages / agg.days_active * 10) / 10 : 0;

  // Response time stats (mirrors Xj9's median/avg computation)
  agg.user_response_times = allResponseTimes;
  if (allResponseTimes.length > 0) {
    const sorted = [...allResponseTimes].sort((a, b) => a - b);
    agg.median_response_time = sorted[Math.floor(sorted.length / 2)] || 0;
    agg.avg_response_time = allResponseTimes.reduce((a, b) => a + b, 0) / allResponseTimes.length;
  }

  // Multi-clauding: detect sessions with overlapping user message timestamps (mirrors Jj9)
  agg.multi_clauding = computeMultiClauding(metas);

  return agg;
}

// Detect overlapping sessions within 30-minute windows (mirrors Jj9 in built-in)
function computeMultiClauding(metas) {
  const events = [];
  for (const m of metas)
    for (const ts of m.user_message_timestamps || [])
      try { events.push({ ts: new Date(ts).getTime(), sessionId: m.session_id }); } catch {}
  events.sort((a, b) => a.ts - b.ts);

  const overlapPairs = new Set();
  const overlapMessages = new Set();
  let windowStart = 0;
  const lastIdx = new Map(); // sessionId -> last index in events

  for (let i = 0; i < events.length; i++) {
    const cur = events[i];
    // Slide window: drop events older than 30 minutes
    while (windowStart < i && cur.ts - events[windowStart].ts > 1800000) {
      const old = events[windowStart];
      if (lastIdx.get(old.sessionId) === windowStart) lastIdx.delete(old.sessionId);
      windowStart++;
    }
    const prevIdx = lastIdx.get(cur.sessionId);
    if (prevIdx !== undefined) {
      // Look for a different session's message between prevIdx and i
      for (let j = prevIdx + 1; j < i; j++) {
        const mid = events[j];
        if (mid.sessionId !== cur.sessionId) {
          const pair = [cur.sessionId, mid.sessionId].sort().join(":");
          overlapPairs.add(pair);
          overlapMessages.add(`${events[prevIdx].ts}:${cur.sessionId}`);
          overlapMessages.add(`${mid.ts}:${mid.sessionId}`);
          overlapMessages.add(`${cur.ts}:${cur.sessionId}`);
          break;
        }
      }
    }
    lastIdx.set(cur.sessionId, i);
  }

  const sessions = new Set();
  for (const pair of overlapPairs) {
    const [a, b] = pair.split(":");
    if (a) sessions.add(a);
    if (b) sessions.add(b);
  }
  return { overlap_events: overlapPairs.size, sessions_involved: sessions.size, user_messages_during: overlapMessages.size };
}

