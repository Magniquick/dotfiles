[Unit]
Description=Quickshell bar, mostly.
Documentation=https://quickshell.org/docs/
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
ExecStart=%E/quickshell/qs
ExecStop=/usr/bin/quickshell kill --path %E/quickshell
Restart=on-failure
RestartPreventExitStatus=SIGABRT
MemoryMax=2G
MemorySwapMax=500M

[Install]
WantedBy=graphical-session.target
